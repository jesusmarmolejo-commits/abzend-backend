# ─────────────────────────────────────────────
# ABZEND Backend — Variables de entorno
# Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────

# Servidor
PORT=3000
NODE_ENV=development

# Supabase
# Encuéntralos en: https://app.supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# JWT (para tokens propios de la app)
JWT_SECRET=cambia_esto_por_una_clave_muy_larga_y_segura_abzend_2024
JWT_EXPIRES_IN=7d

# Stripe
# Encuéntralos en: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# CORS — dominios permitidos (separados por coma)
ALLOWED_ORIGINS=http://localhost:3000,https://abzend.mx

# DeepSeek AI
# Obtén tu API key en: https://platform.deepseek.com → API Keys
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
