# ===================================
# ABZEND Backend — Variables de entorno
# ===================================

# === SUPABASE ===
# Obtener de: https://app.supabase.com → Settings → API
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# === REDIS (Upstash) — RATE LIMITING ===
# Setup: node scripts/setup-upstash.js
# https://upstash.com (free tier)
UPSTASH_REDIS_REST_URL=https://xxxxx-xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxx_xxxxx

# === STRIPE PAGOS ===
# Obtener de: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# === JWT AUTENTICACIÓN ===
# Generar: openssl rand -base64 32
JWT_SECRET=tu-secreto-jwt-muy-largo-y-aleatorio-aqui

# === ENTORNO ===
NODE_ENV=development
PORT=3000

# === CORS DOMINIOS PERMITIDOS ===
# 🔒 SECURITY (HIGH-01): OBLIGATORIA. Si falta o queda vacía, el servidor
# hace console.error y process.exit(1) al arrancar (CORS fail-closed, nunca '*').
# Separa con comas. Los espacios alrededor de cada coma se eliminan automáticamente.
# Producción (Render):
# ALLOWED_ORIGINS=https://abzend-panel-admin.vercel.app,https://abzend-panel-cliente.vercel.app,https://abzend-panel-estacion.vercel.app,https://abzend-panel-gerencial.vercel.app,https://abzend-panel-repartidor.vercel.app,https://abzend-panel-station.vercel.app,https://abzend-tracking-publico.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# === OPCIONAL: CLOUDFLARE (cuando tengas dominio) ===
# CF_ZONE_ID=xxxxx
# CF_API_TOKEN=xxxxx
# CF_RATE_LIMIT_RULE_ID=xxxxx
